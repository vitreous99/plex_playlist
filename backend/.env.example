PLEX_URL=http://127.0.0.1:32400
PLEX_TOKEN=your-plex-token-here
CLIENT_NAME=PlexPlaylist

# Ollama (local LLM server — app runs host-networked, use 127.0.0.1)
OLLAMA_BASE_URL=http://127.0.0.1:11434
DEFAULT_MODEL=gemma:latest

# Database (default: on-disk SQLite cache)
DATABASE_URL=sqlite+aiosqlite:///db/library_cache.db
