# =============================================================================
# Plex Playlist — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Plex Configuration ---
# URL of your Plex Media Server (e.g., http://192.168.1.100:32400)
PLEX_URL=http://your-plex-server:32400

# Plex authentication token
# Find yours at: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=your-plex-token-here

# Name used to identify this application as a Plex client
CLIENT_NAME=PlexPlaylist

# --- Ollama Configuration ---
# Base URL for the Ollama API (default works with Docker Compose networking)
OLLAMA_BASE_URL=http://ollama:11434

# Default LLM model for playlist generation
DEFAULT_MODEL=llama3.2:3b

# --- Database Configuration ---
# Path to the SQLite database file (inside the container)
DATABASE_URL=sqlite+aiosqlite:///db/library_cache.db
