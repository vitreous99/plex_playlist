# =============================================================================
# Plex Playlist — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Plex Configuration ---
# URL of your Plex Media Server (e.g., http://192.168.1.100:32400)
PLEX_URL=http://your-plex-server:32400

# LAN IP used for playback dispatch — must be reachable by all Plex clients on
# the local network. Set to the actual LAN IP of this machine so clients stream
# directly without going via plex.tv relay. (e.g., http://192.168.1.x:32400)
PLEX_LAN_URL=http://your-plex-server-lan-ip:32400

# Plex authentication token
# Find yours at: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=your-plex-token-here

# Name used to identify this application as a Plex client
CLIENT_NAME=PlexPlaylist

# --- Ollama Configuration ---
# Base URL for the Ollama API (app runs host-networked, so use 127.0.0.1 not a Docker service name)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Default LLM model for playlist generation
DEFAULT_MODEL=llama3.2:3b

# --- ADB Bridge Configuration ---
# URL of the ADB Bridge service (for waking Nvidia Shield and sending commands)
ADB_BRIDGE_URL=http://127.0.0.1:9001

# Shield IP address for ADB commands (optional, can be specified per-request)
# Format: 192.168.1.100 (port 5555 is assumed for ADB)
SHIELD_IP=

# --- Keep-Alive Configuration (Prevent Device Sleep During Playback) ---
# Enable keep-alive pings to prevent Shield from sleeping during music playback
KEEP_ALIVE_ENABLED=true

# Duration to keep device awake after playback starts (in minutes)
KEEP_ALIVE_DURATION_MINUTES=90

# Interval between keep-alive pings (in minutes)
KEEP_ALIVE_INTERVAL_MINUTES=10

# --- Database Configuration ---
# Path to the SQLite database file (inside the container)
DATABASE_URL=sqlite+aiosqlite:///db/library_cache.db
